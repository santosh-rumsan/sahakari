# Sahakari App Environment Variables
# Copy this file to .env and fill in the values

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/sahakari?schema=public"

# API Server
PORT=4000
API_BASE_URL="http://localhost:4000"


# Frontend URLs (comma-separated for CORS)
FRONTEND_URL="http://localhost:5173,http://localhost:5174"

# Cloudflare R2 (S3-compatible object storage)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="sahakari-uploads"
R2_PUBLIC_URL="https://pub-xxxx.r2.dev"
R2_UPLOAD_PATH="uploads"
# ^^^ Only used when UPLOAD_LOCAL_PATH is not set
# File uploads — set UPLOAD_LOCAL_PATH to store files on the server disk.
# If not set, uploads fall back to Cloudflare R2.
UPLOAD_LOCAL_PATH="./uploads"
# Maximum upload file size in bytes (default: 1048576 = 1MB)
# MAX_UPLOAD_SIZE_BYTES=1048576

# Sparrow SMS (Nepal)
SPARROW_SMS_API_KEY=""
SPARROW_SMS_API_URL="https://api.sparrowsms.com/v1"
SPARROW_SMS_SENDER_ID=""

# Email OTP Service (existing REST API for sending OTP emails)
EMAIL_SERVICE_URL="https://your-email-service.com/api/send"
EMAIL_SERVICE_API_KEY=""

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Auth
AUTH_SECRET='supersecret'

# App name
APP_NAME="Sahakari"
